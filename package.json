{
  "name": "chief",
  "private": true,
  "workspaces": ["apps/*", "services/*"],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:agents": "uvicorn services/agents/main:app --reload --port 8001",
    "dev": "concurrently -n web,agents -c cyan,yellow --kill-others-on-fail \"npm run dev:web\" \"npm run dev:agents\"",
    "build:web": "npm run build --workspace=apps/web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
